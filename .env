# Neshan API Keys
# هر اندپوینت Neshan API نیاز به توکن جداگانه دارد
# این فایل را به نام .env کپی کنید و توکن‌های خود را وارد کنید

# توکن برای Direction API (مسیریابی)
VITE_NESHAN_DIRECTION_API_KEY=service.c9f64926553e428abe093d2761c95a70

# توکن برای Search API (جستجوی مکان)
# VITE_NESHAN_SEARCH_API_KEY=service.c9f64926553e428abe093d2761c95a70
VITE_NESHAN_SEARCH_API_KEY=service.05d283ecb606445bbe6b1ef685720689

# توکن برای Reverse Geocoding API (تبدیل مختصات به آدرس)
VITE_NESHAN_REVERSE_API_KEY=service.c9f64926553e428abe093d2761c95a70

# توکن برای Quota API (بررسی سهمیه)
VITE_NESHAN_QUOTA_API_KEY=web.29ad84af1e62434586225edb75f79f9d


# توکن عمومی (برای استفاده در جاهای دیگر - اختیاری)
